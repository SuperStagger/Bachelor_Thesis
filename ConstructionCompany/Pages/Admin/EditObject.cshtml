@page "{id:int}"
@model ConstructionCompany.Pages.Admin.EditObjectModel
@{
    ViewData["Title"] = "Редагувати об'єкт";
}

<div class="container py-4">

    <div class="d-flex align-items-center gap-3 mb-4">
        <a href="/Admin/Objects" class="btn btn-outline-secondary btn-sm">
            ← Назад
        </a>
        <h3 class="fw-bold mb-0">Редагувати об'єкт</h3>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-4">
            <form method="post" enctype="multipart/form-data">

                <input type="hidden" name="EditObject.Id"
                       value="@Model.EditObject.Id" />

                <div class="row g-3">

                    <div class="col-12">
                        <label class="form-label fw-semibold">Назва *</label>
                        <input type="text" name="EditObject.Title"
                               class="form-control"
                               value="@Model.EditObject.Title" required />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Категорія *</label>
                        <select name="EditObject.CategoryId"
                                class="form-select" required>
                            <option value="">Оберіть категорію</option>
                            @foreach (var cat in Model.Categories)
                            {
                                <option value="@cat.Value"
                                    selected="@(Model.EditObject.CategoryId.ToString() == cat.Value)">
                                    @cat.Text
                                </option>
                            }
                        </select>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Стан будівництва *</label>
                        <select name="EditObject.BuildingStatus" class="form-select">
                            <option value="InProject"
                                selected="@(Model.EditObject.BuildingStatus == "InProject")">
                                В проекті
                            </option>
                            <option value="UnderConstruction"
                                selected="@(Model.EditObject.BuildingStatus == "UnderConstruction")">
                                Будується
                            </option>
                            <option value="Commissioned"
                                selected="@(Model.EditObject.BuildingStatus == "Commissioned")">
                                Здано в експлуатацію
                            </option>
                        </select>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Статус продажу *</label>
                        <select name="EditObject.SaleStatus" class="form-select">
                            <option value="Available"
                                selected="@(Model.EditObject.SaleStatus == "Available")">
                                Доступний
                            </option>
                            <option value="Reserved"
                                selected="@(Model.EditObject.SaleStatus == "Reserved")">
                                Зарезервований
                            </option>
                            <option value="Sold"
                                selected="@(Model.EditObject.SaleStatus == "Sold")">
                                Проданий
                            </option>
                        </select>
                    </div>

                    @* Видимість і головна — в одному рядку *@
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Публікація</label>
                        <div class="d-flex flex-column gap-2 mt-1">
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox"
                                       name="EditObject.IsHidden"
                                       id="isHiddenCheck"
                                       value="true"
                                       @(Model.EditObject.IsHidden ? "checked" : "") />
                                <label class="form-check-label" for="isHiddenCheck">
                                    Приховати з каталогу (на уточненні)
                                </label>
                            </div>
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox"
                                       name="EditObject.IsFeatured"
                                       id="isFeaturedCheck"
                                       value="true"
                                       @(Model.EditObject.IsFeatured ? "checked" : "") />
                                <label class="form-check-label" for="isFeaturedCheck">
                                    <i class="bi bi-star-fill text-warning me-1"></i>
                                    Показувати на головній сторінці
                                </label>
                            </div>
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox"
                                       name="EditObject.IsProject"
                                       id="isProjectCheck"
                                       value="true"
                                       @(Model.EditObject.IsProject ? "checked" : "") />
                                <label class="form-check-label" for="isProjectCheck">
                                    <i class="bi bi-award text-success me-1"></i>
                                    Включити до "Наших проектів"
                                </label>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-4">
                        <label class="form-label fw-semibold">Ціна *</label>
                        <input type="number" name="EditObject.Price"
                               class="form-control"
                               value="@Model.EditObject.Price.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                               required min="0" step="1000" />
                    </div>

                    <div class="col-md-4">
                        <label class="form-label fw-semibold">Тип ціни *</label>
                        <select name="EditObject.PriceType" class="form-select">
                            <option value="PerObject"
                                selected="@(Model.EditObject.PriceType == "PerObject")">
                                За об'єкт (грн)
                            </option>
                            <option value="PerSqM"
                                selected="@(Model.EditObject.PriceType == "PerSqM")">
                                За м² (грн/м²)
                            </option>
                        </select>
                    </div>

                    <div class="col-md-4">
                        <label class="form-label fw-semibold">Площа (м²) *</label>
                        <input type="number" name="EditObject.Area"
                               class="form-control"
                               value="@Model.EditObject.Area.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                               required min="1" step="0.1" />
                    </div>

                    <div class="col-md-4">
                        <label class="form-label fw-semibold">
                            Рік
                            <span class="text-muted fw-normal small">(початку/здачі)</span>
                        </label>
                        <input type="number" name="EditObject.ProjectYear"
                               class="form-control"
                               value="@Model.EditObject.ProjectYear"
                               min="2020" max="2035" placeholder="напр. 2026" />
                    </div>

                    <div class="col-md-4">
                        <label class="form-label fw-semibold">
                            Квартал здачі
                            <span class="text-muted fw-normal small">(1-4)</span>
                        </label>
                        <select name="EditObject.ProjectQuarter" class="form-select">
                            <option value="">Не вказано</option>
                            <option value="1" selected="@(Model.EditObject.ProjectQuarter == 1)">I квартал</option>
                            <option value="2" selected="@(Model.EditObject.ProjectQuarter == 2)">II квартал</option>
                            <option value="3" selected="@(Model.EditObject.ProjectQuarter == 3)">III квартал</option>
                            <option value="4" selected="@(Model.EditObject.ProjectQuarter == 4)">IV квартал</option>
                        </select>
                    </div>

                    <div class="col-md-4">
                        <label class="form-label fw-semibold">Поверх</label>
                        <input type="number" name="EditObject.Floor"
                               class="form-control"
                               value="@Model.EditObject.Floor" min="1" />
                    </div>

                    <div class="col-md-4">
                        <label class="form-label fw-semibold">Всього поверхів</label>
                        <input type="number" name="EditObject.TotalFloors"
                               class="form-control"
                               value="@Model.EditObject.TotalFloors" min="1" />
                    </div>

                    <div class="col-md-4">
                        <label class="form-label fw-semibold">Кімнат</label>
                        <input type="number" name="EditObject.Rooms"
                               class="form-control"
                               value="@Model.EditObject.Rooms" min="1" />
                    </div>

                    <div class="col-12">
                        <label class="form-label fw-semibold">Адреса *</label>
                        <input type="text" name="EditObject.Address"
                               class="form-control"
                               value="@Model.EditObject.Address" required />
                    </div>

                    @* ── Комерційна нерухомість ───────────────────── *@
                    @{
                        var cats = Model.Categories;
                        var selectedCat = Model.EditObject.CategoryId;
                    }
                    <div class="col-12" id="commercialFields"
                         style="@(Model.EditObject.CommercialType != null ? "" : "")">
                        <div class="card border-0"
                             style="background:var(--bd-cream);">
                            <div class="card-body p-3">
                                <div class="fw-semibold mb-3"
                                     style="color:var(--bd-navy);">
                                    <i class="bi bi-shop me-2"></i>
                                    Параметри комерційної нерухомості
                                </div>
                                <div class="row g-3">
                                    <div class="col-md-6">
                                        <label class="form-label fw-semibold">
                                            Тип комерції
                                        </label>
                                        <select name="EditObject.CommercialType"
                                                class="form-select">
                                            <option value="">Не вказано</option>
                                            <option value="Office"
                                                selected="@(Model.EditObject.CommercialType == "Office")">
                                                Офіс
                                            </option>
                                            <option value="Retail"
                                                selected="@(Model.EditObject.CommercialType == "Retail")">
                                                Торгова площа
                                            </option>
                                            <option value="Warehouse"
                                                selected="@(Model.EditObject.CommercialType == "Warehouse")">
                                                Склад
                                            </option>
                                            <option value="Industrial"
                                                selected="@(Model.EditObject.CommercialType == "Industrial")">
                                                Виробництво
                                            </option>
                                        </select>
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label fw-semibold">
                                            Висота стелі (м)
                                        </label>
                                        <input type="number"
                                               name="EditObject.CeilingHeight"
                                               class="form-control"
                                               value="@Model.EditObject.CeilingHeight?.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                                               min="2" max="20" step="0.1"
                                               placeholder="напр. 3.5" />
                                    </div>
                                    <div class="col-md-6">
                                        <div class="form-check form-switch mt-2">
                                            <input class="form-check-input"
                                                   type="checkbox"
                                                   name="EditObject.HasParking"
                                                   id="hasParkingCheck"
                                                   value="true"
                                                   @(Model.EditObject.HasParking ? "checked" : "") />
                                            <label class="form-check-label"
                                                   for="hasParkingCheck">
                                                <i class="bi bi-p-square me-1"></i>
                                                Є паркінг
                                            </label>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="form-check form-switch mt-2">
                                            <input class="form-check-input"
                                                   type="checkbox"
                                                   name="EditObject.HasSeparateEntrance"
                                                   id="hasEntranceCheck"
                                                   value="true"
                                                   @(Model.EditObject.HasSeparateEntrance ? "checked" : "") />
                                            <label class="form-check-label"
                                                   for="hasEntranceCheck">
                                                <i class="bi bi-door-open me-1"></i>
                                                Окремий вхід
                                            </label>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="col-12">
                        <label class="form-label fw-semibold">Опис</label>
                        <textarea name="EditObject.Description"
                                  class="form-control"
                                  rows="4">@Model.EditObject.Description</textarea>
                    </div>

                    <div class="col-12">
                        <label class="form-label fw-semibold">Додати фотографії</label>
                        <input type="file" name="Photos" class="form-control"
                               multiple accept="image/*" />
                        <div class="form-text">
                            Нові фото додадуться до існуючих.
                            <a href="/Admin/Photos/@Model.EditObject.Id">
                                Управління фото
                            </a>
                        </div>
                    </div>

                </div>

                <div class="d-flex gap-3 mt-4">
                    <button type="submit" class="btn btn-primary px-4">
                        <i class="bi bi-check-lg me-1"></i> Зберегти зміни
                    </button>
                    <a href="/Admin/Objects"
                       class="btn btn-outline-secondary px-4">
                        Скасувати
                    </a>
                </div>

            </form>
        </div>
    </div>
</div>
