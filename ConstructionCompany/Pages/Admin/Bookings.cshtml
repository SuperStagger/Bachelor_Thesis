@* ════════════════════════════════════════════════════════════
   Файл: Pages/Admin/Bookings.cshtml — Управління заявками
   ════════════════════════════════════════════════════════════ *@
@page
@model ConstructionCompany.Pages.Admin.BookingsModel
@{
    ViewData["Title"] = "Заявки";
}

<div class="container py-4">
    <h2 class="fw-bold mb-4">Заявки покупців</h2>

    <div class="card shadow-sm border-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>#</th>
                        <th>Покупець</th>
                        <th>Об'єкт</th>
                        <th>Тип</th>
                        <th>Статус</th>
                        <th>Дата</th>
                        <th>Змінити статус</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var b in Model.Bookings)
                    {
                        var badgeClass = b.BookingStatus == "New"        ? "bg-primary"
                                       : b.BookingStatus == "InProgress" ? "bg-warning text-dark"
                                       : b.BookingStatus == "Completed"  ? "bg-success"
                                       : "bg-secondary";
                        <tr>
                            <td class="text-muted">@b.Id</td>
                            <td>
                                <div class="fw-semibold">@b.User.FullName</div>
                                <div class="small text-muted">@b.User.Email</div>
                            </td>
                            <td>
                                <a href="/Objects/Details/@b.ObjectId"
                                   class="text-decoration-none">
                                    @b.RealEstateObject.Title
                                </a>
                            </td>
                            <td>@b.BookingTypeDisplay</td>
                            <td>
                                <span class="badge @badgeClass">
                                    @b.BookingStatusDisplay
                                </span>
                            </td>
                            <td class="small text-muted">
                                @b.CreatedAt.ToString("dd.MM.yyyy")
                            </td>
                            <td>
                                <form method="post" asp-page-handler="UpdateStatus"
                                      class="d-flex gap-1">
                                    <input type="hidden" name="id" value="@b.Id" />
                                    <select name="status" class="form-select form-select-sm"
                                            style="width:auto;">
                                        <option value="New"
                                            selected="@(b.BookingStatus == "New")">
                                            Нова
                                        </option>
                                        <option value="InProgress"
                                            selected="@(b.BookingStatus == "InProgress")">
                                            В обробці
                                        </option>
                                        <option value="Completed"
                                            selected="@(b.BookingStatus == "Completed")">
                                            Завершена
                                        </option>
                                        <option value="Cancelled"
                                            selected="@(b.BookingStatus == "Cancelled")">
                                            Скасована
                                        </option>
                                    </select>
                                    <button type="submit" class="btn btn-sm btn-outline-primary">
                                        <i class="bi bi-check"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
