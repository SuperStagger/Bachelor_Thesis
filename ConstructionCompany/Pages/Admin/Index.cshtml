@* ════════════════════════════════════════════════════════════
   Файл: Pages/Admin/Index.cshtml — Головна адмін-панелі
   ════════════════════════════════════════════════════════════ *@
@page
@model ConstructionCompany.Pages.Admin.IndexModel
@{
    ViewData["Title"] = "Адмін-панель";
}

<div class="container py-4">
    <h2 class="fw-bold mb-4">Адмін-панель</h2>

    <div class="row g-4 mb-4">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm text-center p-3">
                <div class="display-6 fw-bold text-primary">@Model.ObjectsCount</div>
                <div class="text-muted">Об'єктів</div>
                <a href="/Admin/Objects" class="btn btn-outline-primary btn-sm mt-2">
                    Керувати
                </a>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm text-center p-3">
                <div class="display-6 fw-bold text-warning">@Model.NewBookings</div>
                <div class="text-muted">Нових заявок</div>
                <a href="/Admin/Bookings" class="btn btn-outline-warning btn-sm mt-2">
                    Переглянути
                </a>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm text-center p-3">
                <div class="display-6 fw-bold text-success">@Model.BookingsCount</div>
                <div class="text-muted">Всього заявок</div>
                <a href="/Admin/Bookings" class="btn btn-outline-success btn-sm mt-2">
                    Всі заявки
                </a>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm text-center p-3">
                <div class="display-6 fw-bold text-info">@Model.UsersCount</div>
                <div class="text-muted">Покупців</div>
                <a href="/Admin/Users" class="btn btn-outline-info btn-sm mt-2">
                    Керувати
                </a>
            </div>
        </div>
    </div>

    <div class="list-group">
        <a href="/Admin/Objects"
           class="list-group-item list-group-item-action d-flex align-items-center gap-3">
            <i class="bi bi-building fs-4 text-primary"></i>
            <div>
                <div class="fw-semibold">Управління об'єктами</div>
                <div class="small text-muted">
                    Додавання, редагування, видалення об'єктів нерухомості
                </div>
            </div>
        </a>
        <a href="/Admin/Bookings"
           class="list-group-item list-group-item-action d-flex align-items-center gap-3">
            <i class="bi bi-list-check fs-4 text-success"></i>
            <div>
                <div class="fw-semibold">Управління заявками</div>
                <div class="small text-muted">
                    Перегляд та зміна статусу заявок покупців
                </div>
            </div>
        </a>
        <a href="/Admin/Users"
           class="list-group-item list-group-item-action d-flex align-items-center gap-3">
            <i class="bi bi-people fs-4 text-info"></i>
            <div>
                <div class="fw-semibold">Управління покупцями</div>
                <div class="small text-muted">
                    Перегляд та блокування облікових записів
                </div>
            </div>
        </a>
    </div>
</div>
