@page "{id:int}"
@model ConstructionCompany.Pages.Admin.PhotosModel
@{
    ViewData["Title"] = "Фотографії — " + Model.Object.Title;
}

<div class="container py-4">

    <a href="/Admin/Objects" class="btn btn-outline-secondary btn-sm mb-4">
        ← Назад до об'єктів
    </a>

    <h3 class="fw-bold mb-1">Фотографії</h3>
    <p class="text-muted mb-4">@Model.Object.Title</p>

    @* ── Додати нові фото ──────────────────────────────────── *@
    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body">
            <h6 class="fw-bold mb-3">
                <i class="bi bi-plus-circle me-2"></i>Додати фотографії
            </h6>
            <form method="post" asp-page-handler="Add"
                  enctype="multipart/form-data">
                <input type="hidden" name="objectId" value="@Model.Object.Id" />
                <div class="d-flex gap-3 align-items-end">
                    <div class="flex-grow-1">
                        <input type="file" name="photos" class="form-control"
                               multiple accept="image/*" />
                    </div>
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-upload me-1"></i> Завантажити
                    </button>
                </div>
            </form>
        </div>
    </div>

    @* ── Список фото ───────────────────────────────────────── *@
    @if (!Model.Object.Photos.Any())
    {
        <div class="text-center py-5 text-muted">
            <i class="bi bi-image fs-1"></i>
            <p class="mt-3">Фотографій ще немає</p>
        </div>
    }
    else
    {
        <div class="row g-3">
            @foreach (var photo in Model.Object.Photos)
            {
                var formClass = photo.IsMain ? "flex-grow-1" : "";
                <div class="col-md-3">
                    <div class="card border-0 shadow-sm overflow-hidden">
                        <div style="position:relative;">
                            <img src="@photo.FilePath"
                                 class="w-100"
                                 style="height:180px;object-fit:cover;"
                                 alt="@photo.AltText" />
                            @if (photo.IsMain)
                            {
                                <span class="position-absolute top-0 start-0 m-2 badge"
                                      style="background:var(--bd-gold);
                                             color:var(--bd-navy);">
                                    <i class="bi bi-star-fill me-1"></i>Головне
                                </span>
                            }
                        </div>
                        <div class="card-body p-2 d-flex gap-2">
                            @if (!photo.IsMain)
                            {
                                <form method="post" asp-page-handler="SetMain"
                                      class="flex-grow-1">
                                    <input type="hidden" name="photoId"
                                           value="@photo.Id" />
                                    <input type="hidden" name="objectId"
                                           value="@Model.Object.Id" />
                                    <button type="submit"
                                            class="btn btn-outline-warning btn-sm w-100">
                                        <i class="bi bi-star"></i> Головне
                                    </button>
                                </form>
                            }
                            <form method="post" asp-page-handler="Delete"
                                  onsubmit="return confirm('Видалити фото?')"
                                  class="@formClass">
                                <input type="hidden" name="photoId"
                                       value="@photo.Id" />
                                <input type="hidden" name="objectId"
                                       value="@Model.Object.Id" />
                                <button type="submit"
                                        class="btn btn-outline-danger btn-sm w-100">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            }
        </div>
    }

</div>
