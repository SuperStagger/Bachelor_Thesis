@page
@model ConstructionCompany.Pages.Admin.ObjectsModel
@{
    ViewData["Title"] = "Управління об'єктами";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold mb-0">Об'єкти нерухомості</h2>
        <button class="btn btn-primary" data-bs-toggle="modal"
                data-bs-target="#createModal">
            <i class="bi bi-plus-lg"></i> Додати об'єкт
        </button>
    </div>

    <div class="card shadow-sm border-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Фото</th>
                        <th>Назва</th>
                        <th>Категорія</th>
                        <th>Ціна</th>
                        <th>Площа</th>
                        <th>Статус</th>
                        <th>Здача</th>
                        <th>Дії</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var obj in Model.Objects)
                    {
                        <tr>
                            <td>
                                @if (obj.MainPhoto != null)
                                {
                                    <img src="@obj.MainPhoto.FilePath"
                                         style="width:60px;height:45px;object-fit:cover;"
                                         class="rounded" />
                                }
                                else
                                {
                                    <div class="bg-light rounded d-flex align-items-center
                                                justify-content-center"
                                         style="width:60px;height:45px;">
                                        <i class="bi bi-image text-muted"></i>
                                    </div>
                                }
                            </td>
                            <td class="fw-semibold">@obj.Title</td>
                            <td>@obj.Category.Name</td>
                            <td>@obj.PriceDisplay</td>
                            <td>@obj.Area м²</td>
                            <td>
                                <div class="d-flex gap-1 mb-2 flex-wrap">
                                    <span class="badge @obj.BuildingStatusBadgeClass">
                                        @obj.BuildingStatusDisplay
                                    </span>
                                    @if (obj.SaleStatus == "Reserved")
                                    {
                                        <span class="badge bg-warning text-dark">
                                            Зарезервований
                                        </span>
                                    }
                                </div>
                            </td>
                            <td class="small text-muted">
                                @(obj.DateDisplay ?? "—")
                            </td>
                            <td>
                                <div class="d-flex gap-1">
                                    <a href="/Objects/Details/@obj.Id"
                                       class="btn btn-outline-secondary btn-sm"
                                       title="Переглянути">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    <a href="/Admin/Photos/@obj.Id"
                                       class="btn btn-outline-secondary btn-sm"
                                       title="Фото">
                                        <i class="bi bi-images"></i>
                                    </a>
                                    <a href="/Admin/EditObject/@obj.Id"
                                       class="btn btn-outline-primary btn-sm"
                                       title="Редагувати">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <form method="post" asp-page-handler="Copy"
                                          title="Створити копію об'єкту">
                                        <input type="hidden" name="id" value="@obj.Id" />
                                        <button type="submit" class="btn btn-outline-secondary btn-sm">
                                            <i class="bi bi-copy"></i>
                                        </button>
                                    </form>
                                    <form method="post" asp-page-handler="Delete"
                                          onsubmit="return confirm('Видалити об\'єкт?')">
                                        <input type="hidden" name="id" value="@obj.Id" />
                                        <button type="submit"
                                                class="btn btn-outline-danger btn-sm">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@* ── Модальне вікно: створення ─────────────────────────────── *@
<div class="modal fade" id="createModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title fw-bold">Додати об'єкт</h5>
                <button type="button" class="btn-close"
                        data-bs-dismiss="modal"></button>
            </div>
            <form method="post" asp-page-handler="Create"
                  enctype="multipart/form-data">
                <div class="modal-body">
                    @await Html.PartialAsync("_ObjectForm", Model)
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary"
                            data-bs-dismiss="modal">Скасувати</button>
                    <button type="submit" class="btn btn-primary">
                        Зберегти
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>



