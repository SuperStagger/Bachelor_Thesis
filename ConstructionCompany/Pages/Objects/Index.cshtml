@page
@model ConstructionCompany.Pages.Objects.IndexModel
@{
    ViewData["Title"] = "Каталог нерухомості";
}

<div class="container py-4">

    <h2 class="mb-4 fw-bold">Каталог нерухомості</h2>

    @* ── Фільтри ─────────────────────────────────────────────── *@
    <div class="card mb-4 shadow-sm">
        <div class="card-body">
            <form method="get">
                <input type="hidden" name="PageNumber" value="1" />
                <div class="row g-3 align-items-end">

                    <!-- 1. Категорія -->
                    <div class="col-md-3">
                        <label class="form-label fw-semibold">Категорія</label>
                        <select name="CategoryId" class="form-select">
                            <option value="">Всі категорії</option>
                            @foreach (var cat in Model.Categories)
                            {
                                <option value="@cat.Value"
                                    selected="@(Model.CategoryId.ToString() == cat.Value)">
                                    @cat.Text
                                </option>
                            }
                        </select>
                    </div>

                    <!-- 2. Стан будівництва -->
                    <div class="col-md-2">
                        <label class="form-label fw-semibold">Стан будівництва</label>
                        <select name="BuildingStatus" class="form-select">
                            <option value="">Всі</option>
                            <option value="InProject"
                                selected="@(Model.BuildingStatus == "InProject")">
                                В проекті
                            </option>
                            <option value="UnderConstruction"
                                selected="@(Model.BuildingStatus == "UnderConstruction")">
                                Будується
                            </option>
                            <option value="Commissioned"
                                selected="@(Model.BuildingStatus == "Commissioned")">
                                Здано
                            </option>
                        </select>
                    </div>

                    <!-- 3. Площа -->
                    <div class="col-md-3">
                        <label class="form-label fw-semibold">Площа (м²)</label>
                        <div class="input-group">
                            <input type="number" name="MinArea" class="form-control"
                                   value="@Model.MinArea" placeholder="від" min="0" />
                            <input type="number" name="MaxArea" class="form-control"
                                   value="@Model.MaxArea" placeholder="до" min="0" />
                        </div>
                    </div>

                    <!-- 4. Кімнат -->
                    <div class="col-md-2">
                        <label class="form-label fw-semibold">Кімнат</label>
                        <select name="Rooms" class="form-select">
                            <option value="">Будь-яка</option>
                            <option value="1" selected="@(Model.Rooms == 1)">1</option>
                            <option value="2" selected="@(Model.Rooms == 2)">2</option>
                            <option value="3" selected="@(Model.Rooms == 3)">3</option>
                            <option value="4" selected="@(Model.Rooms == 4)">4</option>
                            <option value="5" selected="@(Model.Rooms == 5)">5+</option>
                        </select>
                    </div>

                    <!-- 5. Ціна -->
                    <div class="col-md-3">
                        <label class="form-label fw-semibold">Ціна (грн)</label>
                        <div class="input-group">
                            <input type="number" name="MinPrice" class="form-control"
                                   value="@Model.MinPrice" placeholder="від" min="0" />
                            <input type="number" name="MaxPrice" class="form-control"
                                   value="@Model.MaxPrice" placeholder="до" min="0" />
                        </div>
                    </div>

                    <!-- Кнопки: пошук + скидання, притиснуті праворуч -->
                    <div class="col-md-3 ms-auto d-flex gap-2">
                        <button type="submit" class="btn btn-primary flex-grow-1">
                            <i class="bi bi-search"></i> Пошук
                        </button>
                        <a href="/Objects" class="btn btn-outline-secondary"
                           title="Скинути фільтри">
                            <i class="bi bi-x-lg"></i> Скинути
                        </a>
                    </div>

                </div>
            </form>
        </div>
    </div>

    @* ── Лічильник ───────────────────────────────────────────── *@
    <div class="d-flex justify-content-between align-items-center mb-3">
        <p class="text-muted mb-0">
            Знайдено: <strong>@Model.TotalCount</strong> об'єктів
            @if (Model.TotalPages > 1)
            {
                <span class="text-muted">
                    · Сторінка @Model.CurrentPage з @Model.TotalPages
                </span>
            }
        </p>
    </div>

    @* ── Сітка карток ────────────────────────────────────────── *@
    @if (!Model.Objects.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-house-slash fs-1 text-muted"></i>
            <p class="mt-3 text-muted">За вашим запитом нічого не знайдено</p>
            <a href="/Objects" class="btn btn-outline-primary">Скинути фільтри</a>
        </div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-3 g-4">
            @foreach (var obj in Model.Objects)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm border-0">

                        @if (obj.MainPhoto != null)
                        {
                            <img src="@obj.MainPhoto.FilePath"
                                 class="card-img-top"
                                 style="height:200px;object-fit:cover;"
                                 alt="@obj.MainPhoto.AltText" />
                        }
                        else
                        {
                            <div class="bg-light d-flex align-items-center
                                        justify-content-center"
                                 style="height:200px;">
                                <i class="bi bi-image text-muted fs-1"></i>
                            </div>
                        }

                        <div class="card-body d-flex flex-column">

                            <div class="d-flex gap-1 mb-2 flex-wrap">
                                <span class="badge @obj.BuildingStatusBadgeClass">
                                    @obj.BuildingStatusDisplay
                                </span>
                                @if (obj.SaleStatus == "Reserved")
                                {
                                    <span class="badge bg-warning text-dark">
                                        Зарезервований
                                    </span>
                                }
                            </div>

                            <h5 class="card-title">@obj.Title</h5>

                            <p class="text-muted small mb-1">
                                <i class="bi bi-geo-alt"></i> @obj.Address
                            </p>

                            <div class="d-flex gap-3 small text-muted mb-2">
                                @if (obj.Area > 0)
                                {
                                    <span>
                                        <i class="bi bi-aspect-ratio"></i> @obj.Area м²
                                    </span>
                                }
                                @if (obj.Rooms.HasValue)
                                {
                                    <span>
                                        <i class="bi bi-door-open"></i> @obj.Rooms кімн.
                                    </span>
                                }
                                @if (obj.Floor.HasValue)
                                {
                                    <span>
                                        <i class="bi bi-layers"></i>
                                        @obj.Floor/@obj.TotalFloors пов.
                                    </span>
                                }
                            </div>

                            @if (obj.DateDisplay != null)
                            {
                                <p class="small mb-2"
                                   style="color:var(--bd-gold);font-weight:600;">
                                    <i class="bi bi-calendar3 me-1"></i>
                                    @obj.DateDisplay
                                </p>
                            }

                            <p class="fw-bold fs-5 mt-auto mb-2"
                               style="color:var(--bd-navy);">
                                @obj.PriceDisplay
                            </p>

                            <a href="/Objects/Details/@obj.Id"
                               class="btn btn-outline-primary btn-sm">
                                Детальніше →
                            </a>

                        </div>
                    </div>
                </div>
            }
        </div>

        @* ── Пагінація ───────────────────────────────────────── *@
        @if (Model.TotalPages > 1)
        {
            <nav class="mt-5 d-flex justify-content-center" aria-label="Пагінація">
                <ul class="pagination">

                    @* Кнопка "Назад" *@
                    <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                        <a class="page-link" href="@BuildUrl(Model.CurrentPage - 1)">
                            <i class="bi bi-chevron-left"></i>
                        </a>
                    </li>

                    @* Сторінки *@
                    @for (int i = 1; i <= Model.TotalPages; i++)
                    {
                        @if (i == 1 || i == Model.TotalPages ||
                             (i >= Model.CurrentPage - 2 && i <= Model.CurrentPage + 2))
                        {
                            <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                                <a class="page-link" href="@BuildUrl(i)">@i</a>
                            </li>
                        }
                        else if (i == Model.CurrentPage - 3 || i == Model.CurrentPage + 3)
                        {
                            <li class="page-item disabled">
                                <span class="page-link">…</span>
                            </li>
                        }
                    }

                    @* Кнопка "Вперед" *@
                    <li class="page-item
                        @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                        <a class="page-link"
                           href="@BuildUrl(Model.CurrentPage + 1)">
                            <i class="bi bi-chevron-right"></i>
                        </a>
                    </li>

                </ul>
            </nav>

            <p class="text-center text-muted small mt-2">
                Показано @Model.Objects.Count з @Model.TotalCount об'єктів
            </p>
        }
    }

</div>

@functions {
    string BuildUrl(int page)
    {
        var q = new System.Collections.Generic.Dictionary<string, string?>
        {
            ["PageNumber"]     = page.ToString(),
            ["CategoryId"]     = Model.CategoryId?.ToString(),
            ["MinPrice"]       = Model.MinPrice?.ToString(),
            ["MaxPrice"]       = Model.MaxPrice?.ToString(),
            ["MinArea"]        = Model.MinArea?.ToString(),
            ["MaxArea"]        = Model.MaxArea?.ToString(),
            ["MinFloor"]       = Model.MinFloor?.ToString(),
            ["Rooms"]          = Model.Rooms?.ToString(),
            ["BuildingStatus"] = Model.BuildingStatus,
        };
        var qs = string.Join("&", q
            .Where(kv => kv.Value != null)
            .Select(kv => $"{kv.Key}={Uri.EscapeDataString(kv.Value!)}"));
        return $"/Objects?{qs}";
    }
}
