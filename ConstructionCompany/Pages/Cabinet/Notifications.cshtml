@page
@model ConstructionCompany.Pages.Cabinet.NotificationsModel
@{
    ViewData["Title"] = "Сповіщення";
}

<div class="container py-4">

    <div class="d-flex align-items-center gap-3 mb-4">
        <a href="/Cabinet/Index" class="btn btn-outline-secondary btn-sm">
            ← Кабінет
        </a>
        <h3 class="fw-bold mb-0">Сповіщення</h3>
    </div>

    @if (!Model.Notifications.Any())
    {
        <div class="text-center py-5 text-muted">
            <i class="bi bi-bell-slash fs-1"></i>
            <p class="mt-3">Сповіщень поки немає</p>
            <a href="/Objects" class="btn btn-outline-primary btn-sm">
                Переглянути каталог
            </a>
        </div>
    }
    else
    {
        <div class="d-flex flex-column gap-2">
            @foreach (var n in Model.Notifications)
            {
                var bgClass = n.IsRead ? "" : "border-warning";
                <div class="card border shadow-sm @bgClass">
                    <div class="card-body d-flex align-items-start gap-3 py-3">
                        <div class="mt-1 flex-shrink-0">
                            @if (!n.IsRead)
                            {
                                <i class="bi bi-bell-fill text-warning fs-5"></i>
                            }
                            else
                            {
                                <i class="bi bi-bell text-muted fs-5"></i>
                            }
                        </div>
                        <div class="flex-grow-1">
                            <div class="@(!n.IsRead ? "fw-semibold" : "")">
                                @n.Message
                            </div>
                            <div class="small text-muted mt-1">
                                @n.CreatedAt.ToString("dd.MM.yyyy HH:mm")
                            </div>
                        </div>
                        @if (!n.IsRead)
                        {
                            <span class="badge bg-warning text-dark flex-shrink-0">
                                Нове
                            </span>
                        }
                    </div>
                </div>
            }
        </div>
    }

</div>
